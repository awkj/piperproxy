        "title": "macOS — 钥匙串访问",
        "step1": "通过上方按钮下载 piper-root.pem。",
        "step2": "双击文件，在「钥匙串访问」中打开。",
        "step3": "在登录钥匙串中找到「Piper Proxy Root CA」。",
        "step4": "双击 → 信任 → 「始终信任」。"
      },
      "linux": {
        "title": "Linux — 系统根 CA 目录",
        "step1": "下载 piper-root.pem。",
        "step2": "执行：sudo cp piper-root.pem /usr/local/share/ca-certificates/piper.crt",
        "step3": "执行：sudo update-ca-certificates"
      },
      "windows": {
        "title": "Windows — 证书存储",
        "step1": "下载 piper-root.pem，将后缀改为 .crt。",
        "step2": "双击 → 安装证书 → 本地计算机。",
        "step3": "选择「将所有证书都放入下列存储」。",
        "step4": "选择「受信任的根证书颁发机构」，确认完成。"
      },
      "ios": {
        "title": "iOS — 描述文件安装",
        "step1": "在 iOS 设备上通过局域网 IP 打开 piper 网页。",
        "step2": "点击「下载根证书」链接。",
        "step3": "进入「设置」→「已下载的描述文件」→「安装」。",
        "step4": "安装后进入「设置」→「通用」→「关于本机」→「证书信任设置」。",
        "step5": "为「Piper Proxy Root CA」开启完全信任。"
      },
      "android": {
        "title": "Android — 用户 CA（Android 7+）",
        "step1": "下载 piper-root.pem 并传输到设备。",
        "step2": "进入「设置」→「安全」→「加密与凭据」→「安装证书」→「CA 证书」。",
        "step3": "选择下载的 piper-root.pem 文件。",
        "step4": "Android 7+ 需在 App 中添加 network_security_config.xml 以信任用户 CA。"
      }
    },
